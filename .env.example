# ================================
# Helix Agent — Configuration
# ================================

# Required: Agent Identity
AGENT_ID=home-pc-1
AGENT_NAME="Home Dev PC"
AGENT_VERSION=2.0.0

# Required: Gateway Connection
GATEWAY_WS_URL=wss://gateway.your-domain.com/agent/ws
AGENT_KEY=your-secret-key-here

# Required: Repository Access
REPO_ROOTS_JSON='["/home/user/projects"]'

# -------- Feature Toggles --------
ENABLE_GIT=true
ENABLE_RUNNER=false
ENABLE_DOCKER=false
ENABLE_HTTP_FETCH=false
ENABLE_SYSTEM_TOOLS=false
ENABLE_UNRESTRICTED_MODE=false

# -------- Security --------
MAX_OUTPUT_BYTES=200000
MAX_FILE_BYTES=2000000
MAX_SEARCH_MATCHES=2000
MAX_TREE_ENTRIES=50000
RUNNER_ALLOWED_COMMANDS=["git","npm","node","python3"]
SENSITIVE_PATTERNS_JSON='["password","secret","token","api_key"]'

# -------- Connection --------
WS_PING_INTERVAL_MS=15000
WS_RECONNECT_MAX_MS=30000
WS_MAX_CONCURRENT_CALLS=4
TOOL_TIMEOUT_MS=30000

# -------- Audit Logging --------
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=/var/log/helix-agent

# -------- Observability --------
LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -------- Database (optional) --------
# DB_CONNECTION_STRING=postgresql://user:pass@localhost:5432/mydb

# -------- Kubernetes (optional) --------
# K8S_NAMESPACE=default
# KUBECONFIG=/home/user/.kube/config
